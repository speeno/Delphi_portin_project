      "phase1_in_scope": true,
      "axes": ["functional", "data"],
      "given": { "S1_Ssub_seeded": true, "S1_Memo_empty": true },
      "request": {
        "method": "GET",
        "path": "/api/v1/transactions/sales-statement/2026.04.10|C001|J001",
        "headers": { "Authorization": "Bearer <hong01>" },
        "query": { "server_id": "main", "gjisa": "" }
      },
      "expect": {
        "status": 200,
        "body_contains": {
          "order_key": { "gdate": "2026.04.10", "hcode": "C001", "jubun": "J001" },
          "lines": [
            { "bcode": "B001", "gsqut": 10, "gssum": 150000 },
            { "bcode": "B002", "gsqut":  5, "gssum": 100000 }
          ],
          "memo": {}
        }
      },
      "legacy_equivalent": "Subu21.pas L669 Select Gbigo,Sbigo,... From S1_Memo",
      "contract_ref": "SQL-INQ-2-DETAIL-STATEMENT + SQL-INQ-3-MEMO-LOAD"
    },
    {
      "id": "TC-INQ-003",
      "title": "거래명세서 메모 PATCH — INSERT (메모 없을 때)",
      "phase1_in_scope": true,
      "axes": ["functional", "data", "audit"],
      "given": { "S1_Memo_empty": true, "auth_token": "hong01" },
      "request": {
        "method": "PATCH",
        "path": "/api/v1/transactions/sales-statement/2026.04.10|C001|J001/memo",
        "headers": { "Authorization": "Bearer <hong01>" },
        "body": {
          "server_id": "main",
          "gjisa": "",
          "gbigo": "긴급 출고",
          "gtel1": "010-1111-2222",
          "gname": "수령인 김"
        }
      },
      "expect": {
        "status": 200,
        "body_contains": { "action": "inserted" },
        "body_has_keys": ["updated_at"]
      },
      "post_check": {
        "db_query": "SELECT Gbigo, Gtel1, Gname FROM S1_Memo WHERE Gdate='2026.04.10' AND Hcode='C001' AND Jubun='J001' AND Gjisa=''",
        "expect_value": { "Gbigo": "긴급 출고", "Gtel1": "010-1111-2222", "Gname": "수령인 김" }
      },
      "audit_check": { "audit_log_count_delta": 1, "action": "inquiry.memo_upsert" },
      "contract_ref": "SQL-INQ-4-MEMO-UPSERT (INSERT branch — Subu21 L1517)"
