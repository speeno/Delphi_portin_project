      "title": "거래명세서 — 기간 정상 조회 (Sobo21 Button101 동등)",
      "phase1_in_scope": true,
      "axes": ["functional", "data"],
      "given": { "S1_Ssub_seeded": true, "auth_token": "hong01" },
      "request": {
        "method": "GET",
        "path": "/api/v1/transactions/sales-statement",
        "headers": { "Authorization": "Bearer <hong01>" },
        "query": {
          "server_id": "main",
          "hcode": "C001",
          "date_from": "2026-04-10",
          "date_to":   "2026-04-12"
        }
      },
      "expect": {
        "status": 200,
        "body_contains": {
          "items": [
            { "order_key": { "gdate": "2026.04.10", "hcode": "C001", "jubun": "J001" }, "row_count": 2, "qty": 15, "amount": 250000, "status": "active" },
