{
  "$schema_note": "Phase1 회귀 팩. migration/contracts/special_master.yaml v1.1.0 1:1.",
  "id": "C9-special-master",
  "contract": "migration/contracts/special_master.yaml",
  "version": "1.1.0-phase1",
  "scope_phase": "phase1",
  "axes": ["functional", "audit"],
  "blockers": [],
  "fixtures": {
    "tables": {
      "G6_Ggeo": [
        { "ID": 42, "Hcode": "H01", "Gcode": "G01", "Bcode": "B01", "Grat1": "10", "Gssum": 100 }
      ]
    }
  },
  "cases": [
    {
      "id": "TC-SPC-001",
      "title": "list(customer) — G6_Ggeo 행 + 거래처/도서명 반환",
      "axes": ["functional"],
      "given": { "auth_token": "admin", "permissions": ["master.special.write", "master.special.read"] },
      "request": { "method": "GET", "path": "/api/v1/masters/special?serverId=remote_1&mode=customer&hcode=H01&gcode=G01" },
      "expected": { "status": 200, "body_contains": { "items": [{ "id": 42, "hcode": "H01", "gcode": "G01", "bcode": "B01" }] } },
      "covers_acceptance": ["AC-SPC-G6-1"]
    },
    {
      "id": "TC-SPC-002",
      "title": "PATCH — Grat1/Gssum 부분 수정",
      "axes": ["functional"],
      "given": { "auth_token": "operator", "permissions": ["master.special.write"] },
      "request": {
        "method": "PATCH", "path": "/api/v1/masters/special/42",
        "body": { "serverId": "remote_1", "hcode": "H01", "grat1": "5", "gssum": 20 }
      },
      "expected": { "status": 200, "body": { "id": 42, "updated_fields": ["grat1", "gssum"] } },
      "covers_acceptance": ["AC-SPC-G6-2"]
    },
    {
      "id": "TC-SPC-003",
      "title": "audit_master — PATCH 이벤트 기록",
      "axes": ["audit"],
      "given": { "auth_token": "admin", "permissions": ["master.special.write"] },
      "request": {
        "method": "PATCH", "path": "/api/v1/masters/special/42",
        "body": { "serverId": "remote_1", "hcode": "H01", "grat1": "5" }
      },
      "expected": { "status": 200 },
      "audit_check": {
        "table": "audit_master",
        "where": { "entity": "special", "entity_id": "42" },
        "expect_columns": { "actor": "*", "before_json": "*", "after_json": "*" }
      },
      "covers_acceptance": ["AC-SPC-G6-2"]
    }
  ]
}
