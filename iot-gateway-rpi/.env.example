# Copy to .env on the Raspberry Pi and adjust.

GATEWAY_SITE_ID=center-seoul-01
LOG_LEVEL=INFO

# Local broker (e.g. Mosquitto on the Pi, receiving ESP32 publishes)
MQTT_LOCAL_HOST=127.0.0.1
MQTT_LOCAL_PORT=1883
# MQTT_LOCAL_USER=
# MQTT_LOCAL_PASSWORD=

# Uplink broker (cloud or HQ)
MQTT_UPLINK_HOST=mqtt.example.com
MQTT_UPLINK_PORT=8883
MQTT_UPLINK_TLS=true
# MQTT_UPLINK_USER=
# MQTT_UPLINK_PASSWORD=

# Wildcard subscribe pattern (MQTT + only)
MQTT_SUBSCRIBE_PATTERN=warehouse/+/+/+/+

# Optional prefix for topics forwarded upstream (empty = keep original topic)
MQTT_UPLINK_TOPIC_PREFIX=

# Wrap JSON with site_id and gateway_ts (1/true to enable)
# GATEWAY_WRAP_JSON=0

# Persistent queue when uplink is down
# Local dev default: writable project path (Pi 운영 시 /var/lib/... 로 변경 가능)
GATEWAY_SQLITE_PATH=./data/queue.db
