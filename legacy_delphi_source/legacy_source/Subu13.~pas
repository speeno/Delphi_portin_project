procedure TSobo13.Button101Click(Sender: TObject);
var St1,St2: String;
begin
  if Base10.Seek_Ggeo(Edit107.Text)='X' Then Exit;

  Tong40.Show;
  Tong40.Update;

  Refresh;
  nSqry.BeforePost:=nil;
  Screen.Cursor:=crHourGlass;
  DataSource1.Enabled:=False;
  Base10.OpenShow(nSqry);

  if Edit108.Text='' Then
     Edit107.Text:='';

  St1:='Hcode'+' ='+#39+Edit107.Text+#39;

  if Edit101.Text<>'' then
  St1:='Hcode'+' ='+#39+Edit107.Text+#39+' and '+
       'Gcode'+' ='+#39+Edit101.Text+#39;

  St2:=' Order By Gcode,Gjisa';

  Sqlen := 'Select * From T1_Gbun Where '+D_Select+St1+St2;

  Base10.Socket.RunSQL(Sqlen);
  Base10.Socket.busyloop;
  if Base10.Socket.body_data <> 'ERROR' then
     Base10.Socket.ClientGrid(nSqry)
  else ShowMessage(E_Open);

  T01:=0;
  nSqry.First;
  ProgressBar1.Max:=nSqry.RecordCount;
  While nSqry.EOF=False do begin
  ProgressBar1.Position:=ProgressBar1.Position+1;

    nSqry.Edit;

    Sqlen := 'Select Gname From G1_Ggeo Where '+D_Select+'Gcode=''@Gcode'' and Hcode=''@Hcode''';
    Translate(Sqlen, '@Gcode', nSqry.FieldByName('Gcode').AsString);
    Translate(Sqlen, '@Hcode', '');
    nSqry.FieldByName('Oname').Value:=Base10.Seek_Name(Sqlen);

    if nSqry.FieldByName('Oname').Value='' then begin
    Sqlen := 'Select Gname From G1_Ggeo Where '+D_Select+'Gcode=''@Gcode'' and Hcode=''@Hcode''';
    Translate(Sqlen, '@Gcode', nSqry.FieldByName('Gcode').AsString);
    Translate(Sqlen, '@Hcode', Edit107.Text);
    nSqry.FieldByName('Oname').Value:=Base10.Seek_Name(Sqlen);
    end;

    nSqry.Post;
    nSqry.Next;
  end;

  nSqry.First;
//Tong20.Srart_16_01(Self);
  DBGrid101.SetFocus;
  ProgressBar1.Position:=0;
  DataSource1.Enabled:=True;
  Screen.Cursor:=crDefault;
  nSqry.BeforePost:=Base10.T2_Sub81BeforePost;

  Tong40.Hide;
{ Tong40.Free; }
end;

