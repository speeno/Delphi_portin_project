procedure TSeek40.FilterTing(Str,Sth:String);
var St1,St2: String;
begin
  Base10.OpenExit(Query1);
  Base10.OpenShow(Query1);

  if Str='' Then Exit;
  Edit3.Text:=Sth;

  St1:='Gcode'+' like '+#39+Str+'%'+#39+' Or '+
       'Gname'+' like '+#39+Str+'%'+#39+' Or '+
       'Gjeja'+' like '+#39+Str+'%'+#39;
  if Lower='1' then
  St1:='Lower(Gcode)'+' like '+'Lower('+#39+'%'+Str+'%'+#39+')'+' Or '+
       'Lower(Gname)'+' like '+'Lower('+#39+'%'+Str+'%'+#39+')'+' Or '+
       'Lower(Gjeja)'+' like '+'Lower('+#39+'%'+Str+'%'+#39+')';
//St1:='(Grat9<>1 or Grat9 is Null)'+' and '+'('+St1+')';
  St1:='Hcode'+'='+#39+Sth+#39+' and '+'('+St1+')';

  if Str < '9____' Then
  St2:=' Order By Gcode' else
  St2:=' Order By Gname';
  St1:=St1+St2;

  if CheckBox1.Checked=True then
  St1:=St1+' Limit 0, 200';

  Sqlen := 'Select Scode,Gubun,Gcode,Ocode,Gname,Gjeja,'+
           'Gdang,Gbjil From G4_Book Where '+St1;
  Base10.Socket.RunSQL(Sqlen);
  Base10.Socket.busyloop;
  if Base10.Socket.body_data <> 'ERROR' then
     Base10.Socket.ClientGrid(Query1)
  else ShowMessage(E_Open);
  Query1.First;
end;

