  ShortDateFormat := 'YYYY.MM.DD';
  LongDateFormat  := 'YYYY.MM.DD';

  D:=StrToDateTime(Edit101.Text+'.01');
  DecodeDate(D, Year,Month,Day);
//Inc(Month);
  if Month > 12 then begin
    Inc(Year);
    Month :=1;
