var St1,St2,St3,St4,St5,St6,St7,St8: String;
begin
//if Base10.Seek_Ggeo(Edit108.Text)='X' Then Exit;

  Tong40.Show;
  Tong40.Update;

  Refresh;
  Screen.Cursor:=crHourGlass;
  DataSource3.Enabled:=False;
  DataSource2.Enabled:=False;
  DataSource1.Enabled:=False;
  Base10.OpenShow(nSqry);
  Base10.OpenShow(mSqry);
  Base10.OpenShow(tSqry);

  St2:='X';

  St1:='Gdate'+'>='+#39+Edit101.Text+#39+' and '+
       'Gdate'+'<='+#39+Edit102.Text+#39+' and '+
       'Gubun'+' ='+#39+'Ăâ°í'+#39+' and '+
       'Ocode'+' ='+#39+'B'+#39+' and '+
       'Scode'+' ='+#39+St2+#39;

  if RadioButton1.Checked=True Then
  St1:=St1+' and '+'Yesno'+' ='+#39+'1'+#39
  else
  if RadioButton2.Checked=True Then
  St1:=St1+' and '+'Yesno'+'<='+#39+'0'+#39
  else
  St1:=St1+' and '+'Yesno'+'>='+#39+'1'+#39;

  if (Edit105.Text<>'') Then
  St1:=St1+' and '+
       'Hcode'+'>='+#39+Edit103.Text+#39+' and '+
       'Hcode'+'<='+#39+Edit105.Text+#39;

  if S_Where1<>'' then
  St1:=St1+' and '+S_Where1;

  St2:=' Order By Gdate,Hcode,Gcode,Gubun,Jubun,Gjisa,ID';

 {-S1_Ssub-}
{ Sqlen :=
  'Select Hcode,Count(Hcode),Sum(Gsqut)as Gsqut,Sum(Gssum)as Gssum '+
  'From S1_Ssub Where '+D_Select+St1+' Group by Hcode ';
  Sqlen := Sqlen+' LIMIT 0,3000 ';

  Base10.Socket.RunSQL(Sqlen);
  Base10.Socket.busyloop;
  if Base10.Socket.body_data <> 'ERROR' then
     Base10.Socket.MakeGrid(SGrid)
  else ShowMessage(E_Open);

  T01:=0; T02:=0; T03:=0; T04:=0;

  List1:=0;
  While SGrid.RowCount-1 > List1 do begin
  List1:=List1+1;
    T01:=T01+1;
    T02:=T02+StrToIntDef(SGrid.Cells[ 1,List1],0);
    T03:=T03+StrToIntDef(SGrid.Cells[ 2,List1],0);
    T04:=T04+StrToIntDef(SGrid.Cells[ 3,List1],0);
  end;

  Edit201.Text:=FormatFloat('########0',T01);
  Edit202.Text:=FormatFloat('########0',T02);
  Edit203.Text:=FormatFloat('###,###,##0',T03);
  Edit204.Text:=FormatFloat('###,###,##0',T04); }

  St3:=' Group By Hcode,Scode,Gdate,Gcode,Bcode,Jubun,Gjisa,Idnum';

  Sqlen := 'Select Hcode,Scode,Gdate,Gcode,Bcode,Jubun,Gjisa,Idnum,Count(*)as Gdang,Sum(Gsqut)as Gsqut,Sum(Gssum)as Gssum '+
           ' From S1_Ssub Where '+D_Select+St1+St3;
  Sqlen := Sqlen+' LIMIT 0,3000 ';

  Base10.Socket.RunSQL(Sqlen);
  Base10.Socket.busyloop;
  if Base10.Socket.body_data <> 'ERROR' then
     Base10.Socket.MakeGrid(SGrid)
  else ShowMessage(E_Open);

  List1:=0;
  ProgressBar1.Max:=SGrid.RowCount;
  While SGrid.RowCount-1 > List1 do begin
  ProgressBar1.Position:=ProgressBar1.Position+1;
  List1:=List1+1;

    St1:=SGrid.Cells[ 0,List1];
    St2:=SGrid.Cells[ 1,List1];
    St3:=SGrid.Cells[ 2,List1];
    St4:=SGrid.Cells[ 3,List1];
    St5:=SGrid.Cells[ 4,List1];
    St6:=SGrid.Cells[ 5,List1];
    St7:=SGrid.Cells[ 6,List1];
    St8:=SGrid.Cells[ 7,List1];

    if nSqry.Locate('Hcode;Gdate;Gcode;Gjisa;Jubun;Bcode;Idnum',VarArrayOf([St1,St3,St4,St7,St6,St5,St8]),[loCaseInsensitive])=False then begin
      nSqry.Append;
      nSqry.FieldByName('Hcode').AsString:=St1;
      nSqry.FieldByName('Scode').AsString:=St2;
      nSqry.FieldByName('Gdate').AsString:=St3;
      nSqry.FieldByName('Gcode').AsString:=St4;
      nSqry.FieldByName('Gjisa').AsString:=St7;
      nSqry.FieldByName('Jubun').AsString:=St6;
      nSqry.FieldByName('Bcode').AsString:=St5;
      nSqry.FieldByName('Idnum').AsString:=St8;
      nSqry.FieldByName('Yesno').AsString:='0';
      nSqry.FieldByName('Gsqut').AsString:=SGrid.Cells[ 9,List1];

      if Base10.G4_Book.Locate('Hcode;Gcode',VarArrayOf([St1,St5]),[loCaseInsensitive])=true then
      nSqry.FieldByName('Bname').AsString:=Base10.G4_Book.FieldByName('Gname').AsString;

      Sqlen := 'Select Gisbn From G4_Book Where '+D_Select+'Gcode=''@Gcode'' and Hcode=''@Hcode''';
      Translate(Sqlen, '@Gcode', St5);
      Translate(Sqlen, '@Hcode', St1);
      nSqry.FieldByName('Gisbn').Value:=Base10.Seek_Name(Sqlen);

      Sqlen := 'Select Yesno,Gnumb From S1_Chek Where '+D_Select+
               'Hcode=''@Hcode'' and Scode=''@Scode'' and '+
               'Gdate=''@Gdate'' and Gcode=''@Gcode'' and '+
               'Jubun=''@Jubun'' and Gjisa=''@Gjisa'' and '+D_Open+
               '`Check`<>''@Check'' ';
      Translate(Sqlen, '@Hcode', St1);
      Translate(Sqlen, '@Scode', 'X');
      Translate(Sqlen, '@Gdate', St3);
      Translate(Sqlen, '@Gcode', St4);
      Translate(Sqlen, '@Jubun', St6);
      Translate(Sqlen, '@Gjisa', St7);
      Translate(Sqlen, '@Check', 'D');
    //St2:=Base10.Seek_Name(Sqlen);
    //if St2='1' then
    //nSqry.FieldByName('Yesno').AsString:=St2;
      Base10.Socket.RunSQL(Sqlen);
      Base10.Socket.BusyLoop;
      if Base10.Socket.Body_Data <> 'NODATA' then begin
        Base10.Socket.MakeData;
        if Base10.Socket.GetData(1, 1)='1' then
        nSqry.FieldByName('Yesno').AsString:='1';
        nSqry.FieldByName('Gnumb').AsString:=Base10.Socket.GetData(1, 2);
      end;

      Sqlen := 'Select Time1 From S1_Chek Where '+D_Select+
               'Hcode=''@Hcode'' and Scode=''@Scode'' and '+
               'Gdate=''@Gdate'' and Gcode=''@Gcode'' and '+
               'Jubun=''@Jubun'' and Gjisa=''@Gjisa'' and '+
               'Bcode=''@Bcode'' and '+D_Open+
               '`Check`<>''@Check'' ';
      Translate(Sqlen, '@Hcode', St1);
      Translate(Sqlen, '@Scode', 'X');
      Translate(Sqlen, '@Gdate', St3);
      Translate(Sqlen, '@Gcode', St4);
      Translate(Sqlen, '@Jubun', St6);
      Translate(Sqlen, '@Gjisa', St7);
      Translate(Sqlen, '@Bcode', St5);
      Translate(Sqlen, '@Check', 'D');
      St2:=Base10.Seek_Name(Sqlen);
      if St2<>'' then
      nSqry.FieldByName('Time1').AsString:=St2;

      Sqlen := 'Select ID,Icode From S1_Ssub Where '+D_Select+
               'Hcode=''@Hcode'' and Scode=''@Scode'' and '+
               'Gdate=''@Gdate'' and Gcode=''@Gcode'' and '+
               'Gubun=''@Gubun'' and Jubun=''@Jubun'' and '+
               'Gjisa=''@Gjisa'' and Ocode=''@Ocode'' ';
      Translate(Sqlen, '@Hcode', St1);
      Translate(Sqlen, '@Scode', 'X');
      Translate(Sqlen, '@Gdate', St3);
      Translate(Sqlen, '@Gcode', St4);
      Translate(Sqlen, '@Gubun', 'Ăâ°í');
      Translate(Sqlen, '@Jubun', St6);
      Translate(Sqlen, '@Gjisa', St7);
      Translate(Sqlen, '@Ocode', 'B');
      Base10.Socket.RunSQL(Sqlen+' Order By Id '+' LIMIT 0,1 ');
      Base10.Socket.busyloop;
      if Base10.Socket.Body_Data <> 'NODATA' then begin
        Base10.Socket.MakeData;
        if Base10.Socket.GetData(1, 2)='' then
        nSqry.FieldByName('Icode').AsString:=Base10.Socket.GetData(1, 1)
        else
        nSqry.FieldByName('Icode').AsString:=Base10.Socket.GetData(1, 2)
      end;


      nSqry.Post;
    end;
  end;

  Button201Click(Self);

