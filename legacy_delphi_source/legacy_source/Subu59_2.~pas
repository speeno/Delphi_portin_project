procedure TSobo59_2.DBGrid301DblClick(Sender: TObject);
var St1: String;
begin
  Screen.Cursor:=crHourGlass;
  oSqry:=nSqry; Bmark:=oSqry.GetBookmark; oSqry.DisableControls;
  oSqry.First;
  St1:='1';
  While oSqry.EOF=False do begin
    if oSqry.FieldByName('Yesno').AsString='1' then
    St1:='2';
    if oSqry.FieldByName('Gsqut').AsFloat<>oSqry.FieldByName('Qsqut').AsFloat then
    St1:='0';
    oSqry.Next;
  end;

  if St1='2' then
  Button103.Enabled:=True
  else
  Button103.Enabled:=False;

  if St1='1' then
  Button102.Enabled:=True
  else
  Button102.Enabled:=False;

  oSqry.GotoBookmark(Bmark); oSqry.FreeBookmark(Bmark); oSqry.EnableControls;
  Screen.Cursor:=crDefault;
end;

