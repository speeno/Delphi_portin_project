       'Ocode'+' ='+#39+'B'+#39+' and '+
       'Scode'+' ='+#39+St2+#39+' and '+
       'Idnum'+' is null'
  else
  St1:='Hcode'+' ='+#39+b_Hcode+#39+' and '+
       'Gdate'+' ='+#39+b_Gdate+#39+' and '+
       'Gcode'+' ='+#39+b_Gcode+#39+' and '+
       'Jubun'+' ='+#39+b_Jubun+#39+' and '+
       'Gubun'+' ='+#39+'출고'+#39+' and '+
       'Ocode'+' ='+#39+'B'+#39+' and '+
       'Scode'+' ='+#39+St2+#39+' and '+
