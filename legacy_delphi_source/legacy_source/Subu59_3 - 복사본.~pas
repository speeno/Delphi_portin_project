  nSqry.First;
  While nSqry.EOF=False do begin
    if nSqry.FieldByName('Gsqut').AsString=nSqry.FieldByName('Qsqut').AsString then begin

      Sqlen := 'INSERT INTO S1_Chek '+
      '(Hcode, Gdate, Scode, Gcode, Ocode, '+
      ' Jubun, Gjisa, Bcode, Gsqut, Yesno, Check, Time1) VALUES '+
      '(''@Hcode'',''@Gdate'',''@Scode'',''@Gcode'',''@Ocode'', '+
      ' ''@Jubun'',''@Gjisa'',''@Bcode'',  @Gsqut  ,''@Yesno'',''@Check'', now())';

