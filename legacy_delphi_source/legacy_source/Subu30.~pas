procedure NavigateIE(const URL: WideString);
var
  IE : Variant;
begin
  try
     IE := CreateOleObject('InternetExplorer.Application');
  except
     ShowMessage('櫛蝶Ы煎楝 褒ч 褒ぬ');
     Exit;
  end;
  IE.Visible := True;
//IE.ToolBar := False;
//IE.Resizable := False;
  IE.TheaterMode := False;
  IE.Left := 0;
  IE.Top := 0;
  IE.Width := Screen.Width;
  IE.Height := Screen.Height;
  IE.Navigate2(URL);
  IE := Unassigned;
end;

