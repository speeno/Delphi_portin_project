procedure TCls_Mulpyo_Happyday.Set_contents(fContent: string);
var
  pPos: integer;
begin
  pPos := Pos('/', fContent);
  if pPos > 0 then
  begin
    uContent_1 := Copy(fContent, 1, pPos);
    uContent_2 := Copy(fContent, pPos + 1, 100);
    Exit;
  end;

  pPos := Pos('(', fContent);
  if pPos > 0 then
  begin
    uContent_1 := Copy(fContent, 1, pPos - 1);
    uContent_2 := Copy(fContent, pPos, 100);
    Exit;
  end;

  pPos := Pos('[', fContent);
  if pPos > 0 then
  begin
    uContent_1 := Copy(fContent, 1, pPos - 1);
    uContent_2 := Copy(fContent, pPos, 100);
    Exit;
  end;
end;

procedure TCls_Mulpyo_Happyday.print_content_cust(fCust_name: string);//АХЗЁУГ(content)
var
  pGap_y: integer;
begin
  uX := 35;
  uY := 85;
  uHeight := 90;
  uBold := 2;
  uAngle := 0;
  uUnderline := 0;
  uFont_name := 'Arial';
  uContent_1 := fCust_name;
  uContent_2 := '';
  //ГЛПы БцРЬАЁ 10 РЬЛѓРЬИщ ГЛПыРЛ 2АГЗЮ ГЊДЉОю 2СйЗЮ УтЗТ РЇЧд
  if Length(uContent_1) > 20 then
  begin
    Set_contents(uContent_1);
  end;

  if uContent_2 = '' then//2ЙјТА ЖѓРЮПЁ УтЗТЧв ГЛПыРЬ ОјРИИщ
  begin
    pGap_y := 50;//1ЖѓРЮИИ УтЗТЧв АцПьПЁДТ ММЗЮЗЮ АЁПюЕЅПЁ ТяБт РЇЧи. КЛЗЁ uYДТ СТЛѓДмРЧ yСТЧЅРг
    windowsfont(uX, uY + pGap_y, uHeight, uAngle, uBold, uUnderline, pChar(uFont_name), pchar(uContent_1))
  end
  else begin//2ЙјТА ЖѓРЮПЁ УтЗТЧв ГЛПыРЬ РжРИИщ
    windowsfont(uX, uY, uHeight, uAngle, uBold, uUnderline, pChar(uFont_name), pchar(uContent_1));
    pGap_y := 85;
    windowsfont(uX, uY + pGap_y, uHeight, uAngle, uBold, uUnderline, pChar(uFont_name), pchar(uContent_2));
  end;
end;

