    Translate(Sqlen, '@Gdate', Sobo21.Edit101.Text);
    Translate(Sqlen, '@Gubun', Sobo21.Edit102.Text);
    Translate(Sqlen, '@Jubun', Sobo21.Edit103.Text);
    Translate(Sqlen, '@Gcode', Sobo21.Edit104.Text);
    Translate(Sqlen, '@Scode', 'X');
    Translate(Sqlen, '@Gjisa', Sobo21.Edit106.Text);
    Translate(Sqlen, '@Hcode', Sobo21.Edit107.Text);
  end;
  if Subu00.ActiveMDIChild.Name='Sobo22' then begin
    Translate(Sqlon, '@Gdate', Edit101.Text);
    Translate(Sqlon, '@Gubun', Edit102.Text);
    Translate(Sqlon, '@Jubun', Edit103.Text);
    Translate(Sqlon, '@Gcode', Edit104.Text);
    Translate(Sqlon, '@Scode', 'Y');
    Translate(Sqlon, '@Gjisa', Edit106.Text);
    Translate(Sqlon, '@Hcode', Edit107.Text);

    Translate(Sqlen, '@Gdate', Sobo22.Edit101.Text);
    Translate(Sqlen, '@Gubun', Sobo22.Edit102.Text);
    Translate(Sqlen, '@Jubun', Sobo22.Edit103.Text);
    Translate(Sqlen, '@Gcode', Sobo22.Edit104.Text);
    Translate(Sqlen, '@Scode', 'Y');
    Translate(Sqlen, '@Gjisa', Sobo22.Edit106.Text);
    Translate(Sqlen, '@Hcode', Sobo22.Edit107.Text);
  end;
  if Subu00.ActiveMDIChild.Name='Sobo23' then begin
    Translate(Sqlon, '@Gdate', Edit101.Text);
    Translate(Sqlon, '@Gubun', Edit102.Text);
    Translate(Sqlon, '@Jubun', Edit103.Text);
