procedure TSobo20.Button201Click(Sender: TObject);
begin
  Sqlon := 'UPDATE S1_Ssub SET '+
  'Scode=''@Scode'',Gcode=''@Gcode'',Hcode=''@Hcode'',Ocode=''@Ocode'', '+
  'Bcode=''@Bcode'',Gubun=''@Gubun'',Jubun=''@Jubun'',Pubun=''@Pubun'', '+
  'Gbigo=''@Gbigo'',Gsqut=  @Gsqut  ,Gdang=  @Gdang  ,Grat1=  @Grat1  , ';
  Sqlen :=
  'Gdate=''@Sdate'',Gjisa=''@Gjisa'',Gssum=  @Gssum '+
  'WHERE ID=@ID and Gdate=''@Gdate''';

  Translate(Sqlon, '@Scode', oSqry.FieldByName('Scode').AsString);
  Translate(Sqlon, '@Gcode', oSqry.FieldByName('Gcode').AsString);
  Translate(Sqlon, '@Hcode', oSqry.FieldByName('Hcode').AsString);
  Translate(Sqlon, '@Ocode', oSqry.FieldByName('Ocode').AsString);
  Translate(Sqlon, '@Bcode', oSqry.FieldByName('Bcode').AsString);
  Translate(Sqlon, '@Gubun', oSqry.FieldByName('Gubun').AsString);
  Translate(Sqlon, '@Jubun', oSqry.FieldByName('Jubun').AsString);
  Translate(Sqlon, '@Pubun', oSqry.FieldByName('Pubun').AsString);
  Translate(Sqlon, '@Gbigo', oSqry.FieldByName('Gbigo').AsString);
  TransAuto(Sqlon, '@Gsqut', oSqry.FieldByName('Gsqut').AsString);
  TransAuto(Sqlon, '@Gdang', oSqry.FieldByName('Gdang').AsString);
  TransAuto(Sqlon, '@Grat1', oSqry.FieldByName('Grat1').AsString);
  Translate(Sqlen, '@Sdate', oSqry.FieldByName('Gdate').AsString);
  Translate(Sqlen, '@Gjisa', oSqry.FieldByName('Gjisa').AsString);
  TransAuto(Sqlen, '@Gssum', oSqry.FieldByName('Gssum').AsString);
  TransAuto(Sqlen, '@ID',    oSqry.FieldByName('ID').AsString);
  Translate(Sqlen, '@Gdate', S_Date);

  Base10.Socket.RunSQL(Sqlon+Sqlen);
  Base10.Socket.BusyLoop;
  if Base10.Socket.Body_Data = 'ERROR' then ShowMessage(E_Update);



  Sqlon := 'UPDATE S1_Memo SET '+
  'Gdate=''@Gdate'' ,Gubun=''@Gubun'' ,Jubun=''@Jubun'' ,'+
  'Gcode=''@Gcode'' ,Scode=''@Scode'' ,Gjisa=''@Gjisa'' ,Hcode=''@Hcode'' ';
  Sqlen :=
  'WHERE Gdate=''@Gdate'' and Gubun=''@Gubun'' '+
  '  and Jubun=''@Jubun'' and Gcode=''@Gcode'' '+
  '  and Scode=''@Scode'' and Gjisa=''@Gjisa'' and Hcode=''@Hcode'' ';

  if Subu00.ActiveMDIChild.Name='Sobo21' then begin
    Translate(Sqlon, '@Gdate', Edit101.Text);
