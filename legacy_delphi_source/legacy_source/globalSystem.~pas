function IsAlpha(const Chr: Char) : Boolean;//ПЕЙЎРкРЮАЁ
begin
  Result := (UpperCase(Chr) >= 'A') and (UpperCase(Chr) <= 'Z');
end;

function Get_UpperCase(const FChr: Char): Char;//МвЙЎРкИІ ДыЙЎРкЗЮ
begin
  if (FChr >= 'a') and (FChr <= 'z') then
    Result := Chr(Byte(FChr) - 32)
  else
    Result := FChr;
end;

function IsKorean(const FParam : string) : Boolean;//УЙЙЎРкАЁ ЧбБлРЮАЁ?
begin
  if FParam = '' then//КѓЙЎРкП­РЬИщ
  begin
    Result := False;
    Exit;
  end;
  Result := Ord(FParam[1]) > 127;
end;

