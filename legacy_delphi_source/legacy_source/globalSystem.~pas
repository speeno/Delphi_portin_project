// Ся, 05.25КЮХЭ ДйРНДо(6Пљ) 24РЯ(25РЯ РќРЯ)БюСіАЁ 1АГПљЗЮ УыБоЕЧБт ЖЇЙЎРЬДй.
function GetMonthPrd2(const FDate1, FDate2: string): Integer;
var
  pYear1,
  pYear2,
  pMonth1,
  pMonth2,
  pDay1,
  pDay2 : Integer;
begin
