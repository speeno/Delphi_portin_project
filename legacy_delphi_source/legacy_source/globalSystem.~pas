function Num2Korean(const Fig1 : Real; Fig2 : integer):string;//М§РкИІ ЧбБлЗЮ ЧЅНУ
//**********************************************
const
  qAA: array[1..4] of string = ('1000000000000', '100000000', '10000', '1');
  qBB: array[1..4, 1..2] of string = (('СЖ', '№М'), ('Оя', 'хт'), ('ИИ', 'иП'), ('', ''));
var
  xHan,
  i: integer;
  FNew,
  FTmp: Real;
begin
  xHan := Fig2;
  FNew := Int(Fig1);

  for i:=1 to 4 do
  begin
    FTmp := Int(FNew / StrToFloat(qAA[i]));
    if FTmp > 0 then
    begin
      FNew  :=FNew - (FTmp * StrToFloat(qAA[i]));
      Result := Result + Num2KoreanA(FTmp, xHan) + qBB[i, xHan];
    end;
  end;
end;

