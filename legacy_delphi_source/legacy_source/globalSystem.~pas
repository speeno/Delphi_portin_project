const
  xA: array[1..9, 1..2] of string = (('РЯ', 'ьь'), ('РЬ', 'ьУ'), ('Ля', 'пГ'),
                                     ('Лч', 'оЬ'), ('ПР', 'чщ'), ('РА', 'ыЛ'),
