function DateInvalid(const FDate : string) : Boolean;// ===== ГЏТЅ РЏШПМК УМХЉ
var
  nDate : TDateTime;
  Year, Month, Day : Word;
begin
  Result := False;

  try
    Year  := StrToInt(Copy(FDate, 1, 4));
    Month := StrToInt(Copy(FDate, 5, 2));
    Day   := StrToInt(Copy(FDate, 7, 2));
    nDate := EncodeDate(Year, Month, Day)
  except on EConvertError do begin
      ShowMessage('ГЏТЅАЁ РЏШПЧЯСі ОЪНРДЯДй !!!');
      Result := True;
    end;
  end;
