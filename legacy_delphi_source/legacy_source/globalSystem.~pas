  pMonth: integer;
begin
  pYear := StrToInt(Copy(FMonth, 1, 4));
  pMonth := StrToInt(Copy(FMonth, 6, 2));

  if FCnt > 0 then
    for pI := 1 to FCnt do
    begin
      Inc(pMonth);
      if pMonth > 12 then
      begin
        Inc(pYear);
        pMonth := 1;
      end;
    end
  else
    for pI := -1 downto FCnt do
    begin
      Dec(pMonth);
      if pMonth < 1 then
      begin
        Dec(pYear);
        pMonth := 12;
      end;
    end;
  Result := IntToStr(pYear) + '.' + FormatFloat('00', pMonth);
end;

