# MariaDB — 스키마 추출(schema_extractor) 등 DB 도구용
# 이 파일은 예시만 담습니다. 실제 값은 프로젝트 루트에 `.env`를 만들어 복사한 뒤 채우세요.
# `.env`는 .gitignore 되어 커밋되지 않습니다. 비밀번호는 레포·대시보드 JSON·문서에 넣지 마세요.

# 후보 호스트가 여러 대일 때, 스키마 추출 시에는 그중 하나를 지정합니다.
MARIADB_HOST=115.68.3.153
MARIADB_PORT=3306
# 레거시 서버는 utf8mb4 미지원인 경우가 있어 클라이언트는 utf8 권장 (schema_extractor 확장 시)
MARIADB_CHARSET=utf8
MARIADB_USER=your_user
MARIADB_PASSWORD=your_password
MARIADB_DATABASE=your_database
# 프로브 4대 기본 호스트 덮어쓰기: MARIADB_HOSTS=ip1,ip2,...

# ── 도서물류관리프로그램 백엔드 — 공공 Open API (비밀은 실제 값만 `.env`에)
# `app/core/config.py` 가 레포 루트·패키지·backend 순으로 `.env` 를 로드합니다.
# 발급 전까지 비워 두면 해당 위젯만 폴백 메시지를 표시합니다.
# 사내 프록시/로컬 CA 환경은 CA 번들 경로를 우선 사용하세요.
# BLS_OPEN_API_CA_BUNDLE=
# 로컬 개발 최후 수단. 운영에서는 사용하지 마세요.
# BLS_OPEN_API_SSL_VERIFY=1

# ITS 국가교통정보센터 (교통 ETA·예측·지도)
# BLS_ITS_API_KEY=
# BLS_ITS_TRAFFIC_BASE_URL=https://openapi.its.go.kr:9443
# BLS_ITS_TRAFFIC_SERVICE_PATH=/trafficInfo
# 예측 API: 포털 공식 Java 샘플은 /bypassFCastInfo (sectionId, fCastDate, fCastHour).
# 백엔드 traffic 클라이언트(forecast=True)는 trafficInfo와 같은 형태의 파라미터로 호출함 → /fcTrafficInfo 등 bbox·링크형 예측과 맞출 것.
# BLS_ITS_FORECAST_SERVICE_PATH=/fcTrafficInfo
# BLS_ITS_REQUEST_TIMEOUT_SEC=5
# BLS_ITS_CACHE_TTL_SEC=300
# BLS_ITS_LINK_MASTER_PATH=

# 기상청 — 단기예보 조회서비스 VilageFcstInfoService_2.0 (날씨 리스크 위젯)
# https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0
# BLS_KMA_API_KEY=
# BLS_KMA_BASE_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0
# BLS_KMA_REQUEST_TIMEOUT_SEC=3
# BLS_KMA_CACHE_TTL_SEC=900
# BLS_KMA_GRID_POINTS_PATH=

# 기상청 — 기상특보 조회서비스 WthrWrnInfoService (특보 위젯)
# https://apis.data.go.kr/1360000/WthrWrnInfoService
# BLS_KMA_WARNING_API_KEY=
# BLS_KMA_WARNING_BASE_URL=https://apis.data.go.kr/1360000/WthrWrnInfoService
# BLS_KMA_WARNING_REQUEST_TIMEOUT_SEC=3
# BLS_KMA_WARNING_CACHE_TTL_SEC=900
# BLS_KMA_WARNING_AREA_PATH=

# 오피넷 — 경유 단가(유가 비용 위젯). 미설정 시 아래 고정 단가로 추정
# BLS_OPINET_CODE=
# BLS_OPINET_API_BASE_URL=https://www.opinet.co.kr/api
# BLS_OPINET_DIESEL_PRODCD=D047
# BLS_OPINET_GASOLINE_PRODCD=B027
# BLS_OPINET_REQUEST_TIMEOUT_SEC=5
# BLS_OPINET_CACHE_TTL_SEC=7200
# BLS_FUEL_DIFF_ALERT_KRW=30
# BLS_DIESEL_PRICE_KRW=1580
