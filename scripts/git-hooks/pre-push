#!/usr/bin/env bash
# Delphi_porting pre-push: 제품 중첩 저장소(도서물류관리프로그램)를 비공개 원격으로 동기화합니다.
# - 상위 push 실패를 막지 않음: 제품 push 실패 시 경고만 stderr 출력 후 exit 0
# - 건너뛰기: SKIP_PRODUCT_REPO_PUSH=1 또는 GIT_PUSH_SKIP_PRODUCT=1

if [[ "${SKIP_PRODUCT_REPO_PUSH:-}" == "1" || "${GIT_PUSH_SKIP_PRODUCT:-}" == "1" ]]; then
  exit 0
fi

TOPLEVEL=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
PRODUCT_DIR="${TOPLEVEL}/도서물류관리프로그램"

if [[ ! -d "$PRODUCT_DIR" ]]; then
  exit 0
fi

if ! git -C "$PRODUCT_DIR" rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

REMOTE=""
if git -C "$PRODUCT_DIR" remote get-url private >/dev/null 2>&1; then
  REMOTE=private
elif git -C "$PRODUCT_DIR" remote get-url origin >/dev/null 2>&1; then
  REMOTE=origin
else
  printf '%s\n' "[git-hooks/pre-push] 도서물류관리프로그램: remote(private 또는 origin)이 없습니다. 비공개 저장소를 추가하세요:" >&2
  printf '%s\n' "  cd \"${PRODUCT_DIR}\" && git remote add private git@github.com:ORG/REPO.git" >&2
  exit 0
fi

PARENT_SHA=$(git -C "$TOPLEVEL" rev-parse --short HEAD 2>/dev/null || echo "?")
PARENT_BRANCH=$(git -C "$TOPLEVEL" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
BRANCH=$(git -C "$PRODUCT_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")

# 변경·미추적 파일이 있으면 스테이징 후 커밋
if [[ -n $(git -C "$PRODUCT_DIR" status --porcelain 2>/dev/null) ]]; then
  git -C "$PRODUCT_DIR" add -A
  if ! git -C "$PRODUCT_DIR" diff --cached --quiet 2>/dev/null; then
    if ! git -C "$PRODUCT_DIR" commit -m "chore(sync): Delphi_porting ${PARENT_BRANCH}@${PARENT_SHA}"; then
      printf '%s\n' "[git-hooks/pre-push] 도서물류관리프로그램: 자동 커밋 실패(무시하고 상위 push 계속)." >&2
    fi
  fi
fi

if ! OUT=$(git -C "$PRODUCT_DIR" push -u "$REMOTE" "$BRANCH" 2>&1); then
  printf '\033[1;33m%s\033[0m\n' "[git-hooks/pre-push] 도서물류관리프로그램 → ${REMOTE}: push 실패. 상위 저장소 push 는 계속됩니다." >&2
  printf '%s\n' "$OUT" >&2
  exit 0
fi

exit 0
